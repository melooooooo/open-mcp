.detail-page {
  min-height: 100vh;
  background: #f5f7fb;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(68rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid #eef1f6;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 600;
}

.nav-text {
  max-width: 420rpx;
}

.back-btn,
.nav-space {
  width: 48rpx;
  height: 48rpx;
  line-height: 42rpx;
  font-size: 54rpx;
  font-weight: 400;
}

.detail-scroll {
  height: calc(100vh - 188rpx);
  box-sizing: border-box;
}

.scroll-bottom-pad {
  height: 190rpx;
}

/* 公司头部 - 全页唯一的主色块 */
.company-hero {
  position: relative;
  overflow: hidden;
  margin: 24rpx 24rpx 22rpx;
  padding: 40rpx 34rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2f6bff 0%, #1d4ed8 100%);
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.18);
}

.hero-glow {
  position: absolute;
  top: -130rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.hero-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.hero-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #1d4ed8;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-info {
  flex: 1;
  min-width: 0;
}

.company-hero-name {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.company-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.hero-tag {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.95);
  font-size: 22rpx;
  font-weight: 400;
}

/* 岗位卡片 */
.position-card {
  margin: 0 24rpx 22rpx;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #eef1f6;
  border-radius: 20rpx;
}

.position-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.position-badge {
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
  background: #eff4ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 500;
}

.position-time {
  color: #9aa3b2;
  font-size: 22rpx;
}

.position-name {
  display: block;
  margin-bottom: 26rpx;
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

/* 关键信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.info-cell {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #eef1f6;
  box-sizing: border-box;
}

.info-cell-icon {
  position: relative;
  flex-shrink: 0;
  width: 46rpx;
  height: 46rpx;
  margin-top: 2rpx;
  border-radius: 12rpx;
  color: #2563eb;
  background: #eff4ff;
}

.info-cell-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-cell-label {
  color: #9aa3b2;
  font-size: 22rpx;
  line-height: 1.2;
}

.info-cell-value {
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.4;
  word-break: break-word;
}

/* 信息图标 (纯 CSS 绘制，统一蓝色) */
.icon-loc::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18rpx;
  height: 18rpx;
  margin: -14rpx 0 0 -9rpx;
  border: 3rpx solid currentColor;
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.icon-loc::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 7rpx;
  height: 7rpx;
  margin: -8rpx 0 0 -3rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-cap::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 18rpx;
  margin: -9rpx 0 0 -12rpx;
  border: 3rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.icon-cap::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 3rpx;
  height: 18rpx;
  margin: -9rpx 0 0 -2rpx;
  background: currentColor;
}

.icon-cal::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 22rpx;
  margin: -10rpx 0 0 -12rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.icon-cal::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 0;
  margin: -4rpx 0 0 -12rpx;
  border-top: 3rpx solid currentColor;
}

.icon-clock::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 22rpx;
  height: 22rpx;
  margin: -11rpx 0 0 -11rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.icon-clock::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 7rpx;
  height: 7rpx;
  margin: -8rpx 0 0 -1rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  box-sizing: border-box;
}

/* 内容卡片 */
.content-card {
  margin: 0 24rpx 22rpx;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #eef1f6;
  border-radius: 20rpx;
}

.block-title {
  position: relative;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.block-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  width: 6rpx;
  height: 28rpx;
  margin-top: -14rpx;
  border-radius: 4rpx;
  background: #2563eb;
}

.paragraphs {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.paragraph-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.paragraph-dot {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 15rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

.paragraph {
  flex: 1;
  min-width: 0;
  color: #475569;
  font-size: 27rpx;
  line-height: 1.8;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 30rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f3f7;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row:first-child {
  padding-top: 0;
}

.info-label {
  flex-shrink: 0;
  color: #9aa3b2;
  font-size: 26rpx;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

/* 底部操作栏 */
.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx calc(30rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid #eef1f6;
}

.collect-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #f1f4f9;
  border: 1rpx solid #e6eaf1;
  box-sizing: border-box;
  transition: background 0.2s ease;
}

.collect-btn.active {
  background: #eff4ff;
  border-color: #d6e2ff;
}

.collect-heart {
  width: 44rpx;
  height: 44rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 44rpx 44rpx;
}

.collect-heart.filled {
  background-image: url("data:image/svg+xml;base64,");
}

.apply-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex: 1;
  height: 96rpx;
  border: none;
  border-radius: 24rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.26);
}

.apply-icon {
  width: 38rpx;
  height: 38rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 38rpx 38rpx;
}

.apply-btn::after {
  border: none;
}

.detail-page {
  min-height: 100vh;
  background: #f9fafb;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(68rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f3f4f6;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.back-btn,
.nav-space {
  width: 48rpx;
  height: 48rpx;
  line-height: 42rpx;
  font-size: 54rpx;
  font-weight: 400;
}

.detail-scroll {
  height: calc(100vh - 188rpx);
  padding-bottom: 170rpx;
  box-sizing: border-box;
}

.summary,
.content-card {
  margin-bottom: 18rpx;
  padding: 36rpx;
  background: #ffffff;
}

.summary-title {
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.32;
}

.company-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 28rpx;
}

.company-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #f3f4f6;
  color: #2563eb;
  font-size: 34rpx;
  font-weight: 900;
}

.company-name,
.company-sub {
  display: block;
}

.company-name {
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 800;
}

.company-sub {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.tag {
  padding: 10rpx 16rpx;
  border-radius: 9rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 23rpx;
}

.tag.danger {
  background: #fef2f2;
  color: #dc2626;
  font-weight: 800;
}

.block-title {
  margin-bottom: 28rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #2563eb;
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.paragraphs {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.paragraph {
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.75;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 26rpx;
}

.info-value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  text-align: right;
  word-break: break-all;
}

.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 22rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
}

.collect-btn {
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.collect-mark {
  position: relative;
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  box-sizing: border-box;
}

.collect-mark::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: -8rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  background: #ffffff;
  transform: rotate(-45deg);
  box-sizing: border-box;
}

.collect-mark.saved {
  color: #f59e0b;
}

.apply-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 88rpx;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.2);
}

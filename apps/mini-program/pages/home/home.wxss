.home-page {
  background: #f8fafc;
}

.hero {
  position: relative;
  padding: 0 0 8rpx;
  background: linear-gradient(180deg, #e6efff 0%, #eef4ff 45%, #f8fafc 100%);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}

.hero-top-safe {
  height: calc(env(safe-area-inset-top) + 12rpx);
}

.banner-card {
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  background: #eef3ff;
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.16);
}

.banner-img {
  display: block;
  width: 100%;
}

.hero-search {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin: -36rpx 28rpx 0;
  padding: 20rpx 20rpx 20rpx 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9aa3b2;
  font-size: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.18);
}

.search-icon {
  margin-right: 14rpx;
  color: #2563eb;
  font-size: 32rpx;
}

.search-go {
  margin-left: auto;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.30);
}

.quick-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  margin-bottom: 32rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.quick-icon {
  display: block;
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.quick-label {
  color: #374151;
  font-size: 24rpx;
  font-weight: 500;
}

.section-title-group {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.section-indicator {
  width: 12rpx;
  height: 32rpx;
  border-radius: 999rpx;
}

.job-indicator {
  background: #2563eb;
}

.experience-indicator {
  background: #4f46e5;
}

.referral-indicator {
  background: #10b981;
}

.jobs-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.job-card {
  padding: 32rpx;
  border: 1rpx solid #f9fafb;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.job-card-pressed {
  transform: scale(0.985);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.job-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.job-company {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.type-chip {
  flex-shrink: 0;
  max-width: 180rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 500;
}

.job-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.job-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-tag.batch-tag {
  background: #eff6ff;
  color: #2563eb;
}

.location-tag {
  max-width: 320rpx;
}

.job-title {
  display: block;
  margin-bottom: 24rpx;
  color: #9ca3af;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.5;
}

.job-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f9fafb;
}

.job-time {
  color: #9ca3af;
  font-size: 22rpx;
}

.job-enter {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 500;
}

.experience-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.experience-card {
  border: 1rpx solid #f9fafb;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  transition: transform 120ms ease, opacity 120ms ease;
}

.content-card-pressed {
  transform: scale(0.985);
  opacity: 0.94;
}

.experience-body {
  padding: 32rpx;
}

.experience-head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.experience-kind {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.experience-hot {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #4f46e5;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.exp-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.42;
  flex: 1;
  min-width: 0;
}

.experience-summary {
  display: -webkit-box;
  margin-bottom: 24rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.experience-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.experience-tag {
  flex-shrink: 0;
  color: #818cf8;
  font-size: 22rpx;
  font-weight: 500;
}

.experience-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #f9fafb;
}

.experience-author {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 16rpx;
}

.experience-avatar {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #e0e7ff 100%);
  color: #4f46e5;
  font-size: 24rpx;
  font-weight: 700;
}

.experience-author-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.experience-author-name {
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 500;
}

.experience-org {
  max-width: 300rpx;
  margin-top: 2rpx;
  color: #9ca3af;
  font-size: 20rpx;
}

.experience-read {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9ca3af;
  font-size: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}

.round-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  color: #9ca3af;
  font-size: 28rpx;
}

.referral-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.ref-card {
  position: relative;
  min-width: 0;
  overflow: hidden;
  border: 1rpx solid #f9fafb;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  transition: transform 120ms ease, opacity 120ms ease;
}

.ref-accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #60a5fa 0%, #34d399 100%);
  opacity: 0.8;
}

.ref-card-body {
  display: flex;
  flex-direction: column;
  padding: 28rpx;
  box-sizing: border-box;
}

.ref-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.ref-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 500;
}

.ref-replies {
  color: #9ca3af;
  font-size: 20rpx;
}

.ref-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.48;
  height: 116rpx;
  margin-bottom: 24rpx;
}

.ref-tags {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 24rpx;
}

.ref-tag {
  max-width: 100%;
  color: #6b7280;
  font-size: 20rpx;
}

.ref-card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 16rpx;
  border-top: 1rpx solid #f9fafb;
}

.ref-footer-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ref-source {
  color: #6b7280;
  font-size: 22rpx;
}

.ref-arrow-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #f9fafb;
  color: #9ca3af;
  font-size: 28rpx;
}

.empty.compact {
  padding: 28rpx 0;
  background: #ffffff;
  border: 1rpx solid #f9fafb;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

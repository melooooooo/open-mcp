.home-page {
  background: #f9fafb;
}

.hero {
  position: relative;
  padding: 0 0 8rpx;
  background: linear-gradient(180deg, #e6efff 0%, #eef4ff 45%, #f9fafb 100%);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}

.hero-top-safe {
  height: calc(env(safe-area-inset-top) + 12rpx);
}

.banner-card {
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  background: #eef3ff;
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.16);
}

.banner-img {
  display: block;
  width: 100%;
}

.hero-search {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin: -36rpx 28rpx 0;
  padding: 20rpx 20rpx 20rpx 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9aa3b2;
  font-size: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.18);
}

.search-icon {
  margin-right: 14rpx;
  color: #2563eb;
  font-size: 32rpx;
}

.search-go {
  margin-left: auto;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.30);
}

.quick-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin: 28rpx 24rpx 0;
  padding: 32rpx 16rpx;
  border-radius: 28rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #374151;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 26rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
}

.quick-icon.blue { background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%); box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28); }
.quick-icon.orange { background: linear-gradient(135deg, #fdba74 0%, #f97316 100%); box-shadow: 0 10rpx 20rpx rgba(249, 115, 22, 0.28); }
.quick-icon.green { background: linear-gradient(135deg, #6ee7b7 0%, #10b981 100%); box-shadow: 0 10rpx 20rpx rgba(16, 185, 129, 0.28); }
.quick-icon.purple { background: linear-gradient(135deg, #c4b5fd 0%, #a855f7 100%); box-shadow: 0 10rpx 20rpx rgba(168, 85, 247, 0.28); }

.jobs-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.job-card {
  display: flex;
  align-items: stretch;
  overflow: hidden;
  border: 1rpx solid #f3f4f6;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.job-card-pressed {
  transform: scale(0.985);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.job-card-bar {
  flex-shrink: 0;
  width: 8rpx;
}

.job-card-body {
  flex: 1;
  min-width: 0;
  padding: 26rpx;
}

.job-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.job-company {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.type-chip {
  flex-shrink: 0;
  max-width: 180rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 21rpx;
  font-weight: 700;
}

.job-title {
  display: block;
  margin-bottom: 14rpx;
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.job-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.job-tag {
  max-width: 100%;
  padding: 6rpx 16rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #f9fafb;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job-tag.batch-tag {
  background: #eff4ff;
  color: #2563eb;
}

.location-tag {
  max-width: 320rpx;
}

.job-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.job-enter {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.type-blue .job-card-bar { background: #3b82f6; }
.type-green .job-card-bar { background: #10b981; }
.type-orange .job-card-bar { background: #f97316; }
.type-cyan .job-card-bar { background: #06b6d4; }

.exp-card {
  padding: 28rpx;
}

.exp-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.exp-card {
  margin-bottom: 22rpx;
}

.exp-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 0;
  color: #6b7280;
  font-size: 24rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #2563eb;
  font-weight: 900;
}

.spacer {
  flex: 1;
}

.referral-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.ref-card {
  min-height: 178rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.ref-badge {
  align-self: flex-start;
  margin-bottom: 14rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
}

.ref-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.42;
}

.meta-row.compact {
  margin-top: auto;
}

.empty.compact {
  padding: 28rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
}

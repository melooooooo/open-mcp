.home-page {
  background: #f9fafb;
}

.hero {
  position: relative;
  padding: 0 0 8rpx;
  background: linear-gradient(180deg, #e6efff 0%, #eef4ff 45%, #f9fafb 100%);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}

.hero-top-safe {
  height: calc(env(safe-area-inset-top) + 12rpx);
}

.banner-card {
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
  background: #eef3ff;
  box-shadow: 0 18rpx 40rpx rgba(37, 99, 235, 0.16);
}

.banner-img {
  display: block;
  width: 100%;
}

.hero-search {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin: -36rpx 28rpx 0;
  padding: 20rpx 20rpx 20rpx 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #9aa3b2;
  font-size: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.18);
}

.search-icon {
  margin-right: 14rpx;
  color: #2563eb;
  font-size: 32rpx;
}

.search-go {
  margin-left: auto;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.30);
}

.quick-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin: 28rpx 24rpx 0;
  padding: 32rpx 16rpx;
  border-radius: 28rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #374151;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 26rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
}

.quick-icon.blue { background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%); box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28); }
.quick-icon.orange { background: linear-gradient(135deg, #fdba74 0%, #f97316 100%); box-shadow: 0 10rpx 20rpx rgba(249, 115, 22, 0.28); }
.quick-icon.green { background: linear-gradient(135deg, #6ee7b7 0%, #10b981 100%); box-shadow: 0 10rpx 20rpx rgba(16, 185, 129, 0.28); }
.quick-icon.purple { background: linear-gradient(135deg, #c4b5fd 0%, #a855f7 100%); box-shadow: 0 10rpx 20rpx rgba(168, 85, 247, 0.28); }

.jobs-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.job-card,
.exp-card {
  padding: 28rpx;
}

.job-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.job-title,
.exp-title {
  flex: 1;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.type-chip {
  flex-shrink: 0;
  max-width: 150rpx;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 800;
}

.company {
  display: block;
  margin-bottom: 16rpx;
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 700;
}

.job-card .tag-row {
  margin-bottom: 18rpx;
}

.exp-card {
  margin-bottom: 22rpx;
}

.exp-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 0;
  color: #6b7280;
  font-size: 24rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #2563eb;
  font-weight: 900;
}

.spacer {
  flex: 1;
}

.referral-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.ref-card {
  min-height: 178rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.ref-badge {
  align-self: flex-start;
  margin-bottom: 14rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 900;
}

.ref-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.42;
}

.meta-row.compact {
  margin-top: auto;
}

.empty.compact {
  padding: 28rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
}

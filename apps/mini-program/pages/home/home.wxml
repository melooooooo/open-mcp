<view class="page home-page">
  <view class="hero">
    <view class="hero-top-safe"></view>
    <view class="banner-card">
      <image class="banner-img" src="/images/home-banner.png" mode="widthFix"></image>
    </view>
    <view class="hero-search" bindtap="goSearch">
      <view class="search-icon icon-search"></view>
      <text>搜索银行、面经、内推...</text>
      <view class="search-go">搜索</view>
    </view>
  </view>

  <view class="quick-card card">
    <view class="quick-item" bindtap="switchTab" data-page="jobs">
      <view class="quick-icon blue">职</view>
      <text>求职导航</text>
    </view>
    <view class="quick-item" bindtap="switchTab" data-page="experiences">
      <view class="quick-icon orange">经</view>
      <text>经验面经</text>
    </view>
    <view class="quick-item" bindtap="switchTab" data-page="referrals">
      <view class="quick-icon green">推</view>
      <text>内推专区</text>
    </view>
    <view class="quick-item" bindtap="switchTab" data-page="jobs">
      <view class="quick-icon purple">新</view>
      <text>最新动态</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">正在加载最新求职信息...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>

  <block wx:else>
    <view class="section">
      <view class="section-head">
        <text class="section-title">最新招聘职位</text>
        <view class="section-more" bindtap="switchTab" data-page="jobs">全部职位</view>
      </view>
      <view wx:if="{{latestJobs.length === 0}}" class="empty compact">暂无最新职位</view>
      <view wx:else class="jobs-list">
        <view wx:for="{{latestJobs}}" wx:key="id" wx:for-item="job" class="job-card card" bindtap="openJob" data-id="{{job.id}}">
          <view class="job-top">
            <text class="job-title line-2">{{job.title}}</text>
            <text class="type-chip">{{job.companyType || '其他'}}</text>
          </view>
          <text class="company line-1">{{job.company}}</text>
          <view class="tag-row">
            <text wx:for="{{job.visibleTags}}" wx:key="*this" class="tag">{{item}}</text>
          </view>
          <view class="meta-row">
            <text class="line-1">地点 {{job.location}}</text>
            <text>时间 {{job.displayTime}}</text>
          </view>
        </view>
      </view> 
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">经验分享</text>
        <view class="section-more" bindtap="switchTab" data-page="experiences">查看更多</view>
      </view>
      <view wx:if="{{experiences.length === 0}}" class="empty compact">暂无经验分享</view>
      <block wx:else>
        <view wx:for="{{experiences}}" wx:key="id" wx:for-item="exp" class="exp-card card" bindtap="openExperience" data-slug="{{exp.slug}}">
          <text class="exp-title line-2">{{exp.title}}</text>
          <view class="exp-meta">
            <text class="avatar">{{exp.authorInitial}}</text>
            <text class="line-1">{{exp.authorName}}</text>
            <text class="spacer"></text>
            <text>浏览 {{exp.viewCount}}</text>
          </view>
          <view class="tag-row">
            <text wx:for="{{exp.visibleTags}}" wx:key="*this" class="tag blue-tag">{{item}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">内推信息</text>
        <view class="section-more" bindtap="switchTab" data-page="referrals">更多内推</view>
      </view>
      <view wx:if="{{referrals.length === 0}}" class="empty compact">暂无内推信息</view>
      <view wx:else class="referral-grid">
        <view wx:for="{{referrals}}" wx:key="id" wx:for-item="ref" class="ref-card card" bindtap="openReferral" data-id="{{ref.id}}">
          <text class="ref-badge">内推</text>
          <text class="ref-title line-2">{{ref.title}}</text>
          <view class="meta-row compact">
            <text>{{ref.publishDate || '近期'}}</text>
            <text wx:if="{{ref.replyCount !== null}}">回复 {{ref.replyCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-tabs">
    <view class="tab-item active"><view class="tab-icon icon-home"></view><text>首页</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="jobs"><view class="tab-icon icon-jobs"></view><text>职位</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="experiences"><view class="tab-icon icon-exp"></view><text>经验</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="profile"><view class="tab-icon icon-profile"></view><text>我的</text></view>
  </view>
</view>

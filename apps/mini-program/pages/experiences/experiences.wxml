<view class="page exp-page">
  <view class="exp-head">
    <text class="exp-page-title">经验分享</text>
    <view class="category-scroll">
      <view class="category-row">
        <button wx:for="{{categories}}" wx:key="value" class="category-btn {{item.value === 'other-financial' ? 'other-financial' : ''}} {{activeCategory === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="changeCategory">{{item.label}}</button>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">正在加载经验...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>
  <view wx:elif="{{experiences.length === 0}}" class="empty">暂无匹配经验</view>
  <view wx:else class="exp-list">
    <view wx:for="{{experiences}}" wx:key="id" wx:for-item="exp" class="exp-card card" bindtap="openExperience" data-slug="{{exp.slug}}">
      <text class="exp-title line-2">{{exp.title}}</text>
      <view class="exp-meta">
        <text class="avatar">{{exp.authorInitial}}</text>
        <text>{{exp.authorName}}</text>
        <text class="spacer"></text>
        <text>浏览 {{exp.viewCount}}</text>
      </view>
      <view class="tag-row">
        <text wx:for="{{exp.visibleTags}}" wx:key="*this" class="tag blue-tag">{{item}}</text>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="loading more">继续加载...</view>
  </view>

  <view class="bottom-tabs">
    <view class="tab-item" bindtap="switchTab" data-page="home"><view class="tab-icon icon-home"></view><text>首页</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="jobs"><view class="tab-icon icon-jobs"></view><text>职位</text></view>
    <view class="tab-item active"><view class="tab-icon icon-exp"></view><text>经验</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="profile"><view class="tab-icon icon-profile"></view><text>我的</text></view>
  </view>
</view>

<view class="page exp-page">
  <view class="exp-head">
    <text class="exp-page-title">经验分享</text>
    <scroll-view scroll-x class="category-scroll" show-scrollbar="{{false}}">
      <view class="category-row">
        <button wx:for="{{categories}}" wx:key="*this" class="category-btn {{activeCategory === item ? 'active' : ''}}" data-value="{{item}}" bindtap="changeCategory">{{item}}</button>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="loading">正在加载经验...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>
  <view wx:elif="{{experiences.length === 0}}" class="empty">暂无匹配经验</view>
  <view wx:else class="exp-list">
    <view wx:for="{{experiences}}" wx:key="id" wx:for-item="exp" class="exp-card card" bindtap="openExperience" data-slug="{{exp.slug}}">
      <text class="exp-title line-2">{{exp.title}}</text>
      <view class="exp-meta">
        <text class="avatar">{{exp.authorInitial}}</text>
        <text>{{exp.authorName}}</text>
        <text class="spacer"></text>
        <text>◉ {{exp.viewCount}}</text>
      </view>
      <view class="tag-row">
        <text wx:for="{{exp.visibleTags}}" wx:key="*this" class="tag blue-tag">{{item}}</text>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="loading more">继续加载...</view>
  </view>

  <view class="bottom-tabs">
    <view class="tab-item" bindtap="switchTab" data-page="home"><text class="tab-icon">⌂</text><text>首页</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="jobs"><text class="tab-icon">▣</text><text>职位</text></view>
    <view class="tab-item active"><text class="tab-icon">▤</text><text>经验</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="profile"><text class="tab-icon">○</text><text>我的</text></view>
  </view>
</view>


.article-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #f9fafb;
}

.article-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(68rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f3f4f6;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.back-btn,
.nav-space {
  width: 48rpx;
  height: 48rpx;
  line-height: 42rpx;
  font-size: 54rpx;
  font-weight: 400;
}

.article-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.article-cover {
  display: block;
  width: calc(100% - 56rpx);
  height: 360rpx;
  margin: 28rpx auto 0;
  border-radius: 24rpx;
  background: #e5e7eb;
}

.cover-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 56rpx);
  height: 240rpx;
  margin: 28rpx auto 0;
  border-radius: 24rpx;
  background: #f3f4f6;
  color: #9ca3af;
  font-size: 25rpx;
}

.article-header,
.article-body {
  margin-bottom: 18rpx;
  padding: 36rpx;
  background: #ffffff;
}

.article-title {
  display: block;
  color: #111827;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.38;
}

.article-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
}

.article-summary {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #4b5563;
  font-size: 27rpx;
  line-height: 1.7;
}

.article-body {
  padding-top: 28rpx;
  padding-bottom: 48rpx;
}

.article-content,
.empty-content {
  display: block;
  color: #374151;
  font-size: 30rpx;
  line-height: 1.8;
}

.related-links {
  margin-top: 44rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #e5e7eb;
}

.related-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.related-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.related-hint {
  color: #9ca3af;
  font-size: 22rpx;
}

.related-link {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 14rpx;
  padding: 22rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  background: #eff6ff;
}

.related-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.related-label {
  flex: 1;
  min-width: 0;
  color: #1d4ed8;
  font-size: 27rpx;
  line-height: 1.5;
}

.related-copy {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.article-actions {
  display: flex;
  flex-shrink: 0;
  gap: 24rpx;
  padding: 22rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
}

.like-btn,
.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 86rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.like-btn {
  gap: 10rpx;
  width: 180rpx;
  background: #fff7ed;
  color: #f97316;
}

.like-btn.active {
  background: #f97316;
  color: #ffffff;
}

.like-mark {
  position: relative;
  flex-shrink: 0;
  width: 22rpx;
  height: 22rpx;
  background: currentColor;
  border-radius: 4rpx;
  transform: translateY(1rpx) rotate(-45deg);
}

.like-mark::before,
.like-mark::after {
  content: "";
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.like-mark::before {
  left: 0;
  top: -11rpx;
}

.like-mark::after {
  left: 11rpx;
  top: 0;
}

.share-btn {
  flex: 1;
  background: #2563eb;
  color: #ffffff;
}

.action-label {
  display: block;
  line-height: 32rpx;
}

.article-skeleton {
  flex: 1;
  padding: 28rpx 36rpx;
  background: #ffffff;
}

.skeleton-block {
  border-radius: 12rpx;
  background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.4s infinite;
}

.skeleton-cover {
  height: 360rpx;
  margin-bottom: 36rpx;
  border-radius: 24rpx;
}

.skeleton-title {
  width: 86%;
  height: 58rpx;
  margin-bottom: 24rpx;
}

.skeleton-meta {
  width: 62%;
  height: 28rpx;
  margin-bottom: 64rpx;
}

.skeleton-line {
  height: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-line.short {
  width: 72%;
}

.error-state {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.error-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.error-message {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 26rpx;
  text-align: center;
}

.retry-button {
  width: 240rpx;
  margin-top: 32rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

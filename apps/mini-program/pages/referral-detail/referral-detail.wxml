<view class="ref-detail">
  <view class="detail-nav">
    <view class="back-btn icon-back" bindtap="goBack"></view>
    <text>内推详情</text>
    <view class="nav-space"></view>
  </view>
  <view wx:if="{{loading}}" class="loading">正在加载内推...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>
  <block wx:elif="{{referral}}">
    <view class="header">
      <text class="title">{{referral.title}}</text>
      <view class="meta">
        <text>{{referral.publishDate || '近期'}}</text>
        <text>· {{referral.replyCount || 0}} 回复</text>
      </view>
    </view>
    <view class="content">
      <block wx:for="{{contentBlocks}}" wx:key="id" wx:for-item="block">
        <view wx:if="{{block.type === 'header'}}" class="jd-header">{{block.text}}</view>
        <view wx:elif="{{block.type === 'subheader'}}" class="jd-subheader">{{block.text}}</view>
        <view wx:elif="{{block.type === 'list'}}" class="jd-list">
          <text class="jd-marker">{{block.marker}}</text>
          <text class="jd-list-body" user-select="{{true}}">
            <block wx:for="{{block.segments}}" wx:key="id" wx:for-item="seg">
              <text wx:if="{{seg.kind === 'text'}}">{{seg.text}}</text>
              <text wx:else class="jd-link" data-text="{{seg.text}}" catchtap="copySegment">{{seg.text}}</text>
            </block>
          </text>
        </view>
        <text wx:else class="jd-paragraph" user-select="{{true}}">
          <block wx:for="{{block.segments}}" wx:key="id" wx:for-item="seg">
            <text wx:if="{{seg.kind === 'text'}}">{{seg.text}}</text>
            <text wx:else class="jd-link" data-text="{{seg.text}}" catchtap="copySegment">{{seg.text}}</text>
          </block>
        </text>
      </block>
    </view>
    <view class="actions bottom-actions">
      <button class="collect secondary-button {{referral.isCollected ? 'active' : ''}}" bindtap="toggleCollect">
        {{referral.isCollected ? '已收藏' : '收藏'}}
      </button>
      <button class="copy primary-button" bindtap="copyLink">复制原帖链接</button>
    </view>
  </block>
</view>

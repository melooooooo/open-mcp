.ref-detail {
  min-height: 100vh;
  background: #f9fafb;
  padding-bottom: 150rpx;
}

.detail-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(68rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f3f4f6;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.back-btn,
.nav-space {
  width: 48rpx;
  height: 48rpx;
  line-height: 42rpx;
  font-size: 54rpx;
  font-weight: 400;
}

.header,
.content {
  margin-bottom: 18rpx;
  padding: 36rpx;
  background: #ffffff;
}

.title {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.4;
}

.meta {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.paragraph {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.72;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 22rpx;
  padding: 22rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
}

.collect,
.copy {
  height: 86rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 86rpx;
}

.collect {
  width: 180rpx;
  background: #fff7ed;
  color: #f97316;
}

.collect.active {
  background: #f97316;
  color: #ffffff;
}

.copy {
  flex: 1;
  background: #2563eb;
  color: #ffffff;
}


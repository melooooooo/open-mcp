.profile-page {
  background: #f4f6fb;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 0 32rpx 40rpx;
  background: linear-gradient(165deg, #2563eb 0%, #3b82f6 48%, #60a5fa 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.hero-top-safe {
  height: calc(env(safe-area-inset-top) + 96rpx);
}

.hero-bg-circle {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  pointer-events: none;
}

.circle-a {
  top: -120rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
}

.circle-b {
  top: 60rpx;
  left: -110rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
}

.profile-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 8rpx 8rpx 36rpx;
}

.avatar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  background: #dbeafe;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.22);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  color: #2563eb;
  font-size: 52rpx;
  font-weight: 900;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.user-sub {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.role-pill {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.sub-text {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.edit-entry {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  align-self: flex-end;
  margin-bottom: 6rpx;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #2563eb;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.18);
}

.edit-entry:active {
  transform: scale(0.96);
  background: #eff6ff;
}

.edit-entry-icon {
  font-size: 26rpx;
  line-height: 1;
}

.stats-card {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  border-radius: 18rpx;
  transition: background 120ms ease, transform 120ms ease;
}

.stat-item:active {
  transform: scale(0.96);
  background: #f3f6fb;
}

.stat-num {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.divider {
  width: 1rpx;
  height: 56rpx;
  background: #eef0f5;
}

.visitor-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 2;
  padding: 30rpx;
}

.visitor-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.visitor-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.visitor-desc {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.55;
}

.visitor-button {
  flex-shrink: 0;
  margin: 0;
  padding: 0 30rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 80rpx;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.25);
}

.editor-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.45);
}

.editor-sheet {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 36rpx);
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 -10rpx 40rpx rgba(15, 23, 42, 0.18);
}

.editor-grabber {
  align-self: center;
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
}

.editor-arrow {
  margin-left: auto;
  color: #c4c8d2;
}

.editor-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.editor-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.editor-desc {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.avatar-picker-wrap {
  position: relative;
  align-self: center;
  width: 152rpx;
  height: 152rpx;
  margin: 8rpx 0 0;
}

.avatar-picker {
  width: 152rpx;
  height: 152rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: transparent;
  line-height: normal;
  overflow: hidden;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview {
  display: block;
  width: 152rpx;
  height: 152rpx;
  border-radius: 999rpx;
  border: 4rpx solid #eef2ff;
  box-sizing: border-box;
  background: #e5e7eb;
}

.avatar-preview-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 152rpx;
  height: 152rpx;
  border-radius: 999rpx;
  border: 4rpx solid #eef2ff;
  box-sizing: border-box;
  background: #dbeafe;
  color: #2563eb;
  font-size: 56rpx;
  font-weight: 900;
}

.avatar-cam {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  background: #2563eb;
  box-sizing: border-box;
  pointer-events: none;
}

.avatar-cam::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 16rpx;
  transform: translate(-50%, -50%);
  border-radius: 5rpx;
  background: #ffffff;
}

.avatar-cam::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  transform: translate(-50%, -50%);
  border: 2rpx solid #2563eb;
  border-radius: 999rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.avatar-tip {
  align-self: center;
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.profile-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-input {
  padding: 26rpx 28rpx;
  border: 1rpx solid #eef0f5;
  border-radius: 18rpx;
  background: #f7f8fb;
  color: #111827;
  font-size: 30rpx;
  text-align: center;
}

.profile-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 6rpx;
}

.profile-secondary,
.profile-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  height: 84rpx;
  border-radius: 18rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
}

.profile-secondary::after,
.profile-primary::after {
  border: none;
}

.profile-secondary {
  background: #ffffff;
  color: #374151;
  border: 1rpx solid #e5e7eb;
}

.profile-primary {
  background: #2563eb;
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.22);
}

.menu-card {
  margin: 28rpx 32rpx 0;
  padding: 8rpx 0;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  transition: background 120ms ease;
}

.menu-row:active {
  background: #f7f9fd;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.menu-text {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.icon-feedback {
  background: #fff7ed;
  color: #f97316;
}

.icon-about {
  background: #eef2ff;
  color: #4f46e5;
}

.icon-logout {
  background: #fef2f2;
  color: #dc2626;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.menu-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.version {
  margin-top: 44rpx;
  color: #9ca3af;
  text-align: center;
  font-size: 22rpx;
}

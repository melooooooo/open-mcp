.profile-page {
  background: #f9fafb;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: calc(112rpx + env(safe-area-inset-top)) 48rpx 42rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.avatar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  overflow: hidden;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  background: #dbeafe;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.14);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  color: #2563eb;
  font-size: 48rpx;
  font-weight: 900;
}

.user-name,
.user-sub {
  display: block;
}

.user-name {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
}

.user-sub {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.visitor-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin: 32rpx 32rpx 0;
  padding: 30rpx;
}

.visitor-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.visitor-desc {
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.6;
}

.visitor-button {
  margin-top: 8rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 36rpx 40rpx;
  background: #ffffff;
}

.profile-editor {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin: 32rpx 32rpx 0;
  padding: 30rpx;
}

.editor-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.editor-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.editor-desc {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.avatar-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  background: transparent;
  text-align: left;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #e5e7eb;
}

.avatar-preview-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #2563eb;
  font-size: 36rpx;
  font-weight: 900;
}

.avatar-picker-text {
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 800;
}

.profile-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-label {
  color: #374151;
  font-size: 24rpx;
  font-weight: 800;
}

.profile-input {
  padding: 22rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #f9fafb;
  color: #111827;
  font-size: 28rpx;
}

.profile-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 4rpx;
}

.profile-secondary,
.profile-primary {
  height: 76rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.profile-secondary::after,
.profile-primary::after {
  border: none;
}

.profile-secondary {
  background: #ffffff;
  color: #374151;
  border: 1rpx solid #e5e7eb;
}

.profile-primary {
  background: #2563eb;
  color: #ffffff;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.divider {
  width: 1rpx;
  height: 58rpx;
  background: #f3f4f6;
}

.menu-card {
  margin: 32rpx;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #374151;
  font-size: 28rpx;
  font-weight: 800;
}

.menu-icon {
  width: 46rpx;
  color: #6b7280;
  font-size: 34rpx;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.menu-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.version {
  margin-top: 42rpx;
  color: #9ca3af;
  text-align: center;
  font-size: 22rpx;
}

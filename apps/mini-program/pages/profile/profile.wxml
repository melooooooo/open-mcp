<view class="page profile-page">
  <view class="profile-hero">
    <view class="hero-top-safe"></view>
    <view class="hero-bg-circle circle-a"></view>
    <view class="hero-bg-circle circle-b"></view>

    <view class="profile-head">
      <view class="avatar-wrap">
        <image wx:if="{{user && user.image}}" src="{{user.image}}" class="avatar-img" mode="aspectFill"></image>
        <text wx:else class="avatar-fallback">{{user.initial || '同'}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{user.name || '同学'}}</text>
        <view class="user-sub">
          <text class="role-pill">{{user.roleLabel || '公测版'}}</text>
          <text class="sub-text">{{user.address || '游客模式'}}</text>
        </view>
      </view>
      <view wx:if="{{isLoggedIn}}" class="edit-entry" bindtap="toggleProfileEditor">
        <text class="edit-entry-icon">✎</text>
        <text class="edit-entry-text">编辑资料</text>
      </view>
    </view>

    <view wx:if="{{isLoggedIn}}" class="stats-card card">
      <view class="stat-item" bindtap="openMyContent" data-tab="collections">
        <text class="stat-num">{{stats.collections}}</text>
        <text class="stat-label">我的收藏</text>
      </view>
      <view class="divider"></view>
      <view class="stat-item" bindtap="openMyContent" data-tab="likes">
        <text class="stat-num">{{stats.likes}}</text>
        <text class="stat-label">我的点赞</text>
      </view>
      <view class="divider"></view>
      <view class="stat-item" bindtap="showHistoryTodo">
        <text class="stat-num">{{stats.history}}</text>
        <text class="stat-label">浏览历史</text>
      </view>
    </view>

    <view wx:else class="visitor-card card">
      <view class="visitor-text">
        <text class="visitor-title">公测版已开放内容浏览</text>
        <text class="visitor-desc">登录后可以收藏职位、内推信息，并同步经验点赞。</text>
      </view>
      <button class="visitor-button" loading="{{loading}}" bindtap="handleWechatLogin">微信一键登录</button>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-row" bindtap="showFeedback">
      <view class="menu-left"><text class="menu-icon icon-feedback">反</text><text class="menu-text">意见反馈</text></view>
      <view class="menu-right"><view class="menu-arrow"></view></view>
    </view>
    <view class="menu-row" bindtap="showAbout">
      <view class="menu-left"><text class="menu-icon icon-about">关</text><text class="menu-text">关于我们</text></view>
      <view class="menu-right"><view class="menu-arrow"></view></view>
    </view>
    <view wx:if="{{isLoggedIn}}" class="menu-row" bindtap="handleLogout">
      <view class="menu-left"><text class="menu-icon icon-logout">退</text><text class="menu-text">退出登录</text></view>
      <view class="menu-right"><view class="menu-arrow"></view></view>
    </view>
  </view>

  <view class="version">银行帮 v1.0.0</view>

  <view class="bottom-tabs">
    <view class="tab-item" bindtap="switchTab" data-page="home"><view class="tab-icon icon-home"></view><text>首页</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="jobs"><view class="tab-icon icon-jobs"></view><text>职位</text></view>
    <view class="tab-item" bindtap="switchTab" data-page="experiences"><view class="tab-icon icon-exp"></view><text>经验</text></view>
    <view class="tab-item active"><view class="tab-icon icon-profile"></view><text>我的</text></view>
  </view>

  <view wx:if="{{isLoggedIn && showProfileEditor}}" class="editor-mask" bindtap="cancelEdit">
    <view class="editor-sheet" catchtap="noop">
      <view class="editor-grabber"></view>
      <text class="editor-title">{{isProfileIncomplete ? '完善资料' : '编辑资料'}}</text>

      <view class="avatar-picker-wrap">
        <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
          <image wx:if="{{profileForm.image}}" src="{{profileForm.image}}" class="avatar-preview" mode="aspectFill"></image>
          <text wx:else class="avatar-preview-fallback">{{user.initial || '同'}}</text>
        </button>
        <view class="avatar-cam"></view>
      </view>
      <text class="avatar-tip">点击使用微信头像，或自定义</text>

      <view class="profile-field">
        <input class="profile-input" type="nickname" value="{{profileForm.name}}" placeholder="点击填写昵称" bindinput="handleNameInput" bindblur="handleNameInput" />
      </view>

      <view class="profile-actions">
        <button class="profile-secondary" loading="{{savingProfile}}" bindtap="cancelEdit">取消</button>
        <button class="profile-primary" loading="{{savingProfile}}" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>

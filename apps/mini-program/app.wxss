page {
  min-height: 100%;
  background: #f9fafb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding-bottom: 156rpx;
  background: #f9fafb;
  box-sizing: border-box;
}

.nav-title {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(76rpx + env(safe-area-inset-top)) 32rpx 22rpx;
  background: #ffffff;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.04);
}

.section {
  padding: 0 32rpx;
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.section-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.section-title.small {
  font-size: 28rpx;
}

.section-more {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 24rpx;
  white-space: nowrap;
}

.section-more::after {
  content: "";
  width: 12rpx;
  height: 12rpx;
  margin-left: 8rpx;
  border-top: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid #f3f4f6;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.3;
}

.blue-tag {
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
}

.danger-tag {
  background: #fef2f2;
  color: #dc2626;
  font-weight: 800;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.muted {
  color: #6b7280;
}

.primary {
  color: #2563eb;
}

.primary-bg {
  background: #eff6ff;
  color: #2563eb;
}

.bottom-tabs {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 14rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
  box-shadow: 0 -8rpx 18rpx rgba(15, 23, 42, 0.03);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #9ca3af;
  font-size: 20rpx;
  font-weight: 600;
}

.tab-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  background: transparent;
  color: inherit;
}

.tab-item.active {
  color: #2563eb;
}

.tab-item.active .tab-icon {
  background: #eff6ff;
}

.icon-home::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 22rpx;
  width: 20rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 4rpx 4rpx;
  box-sizing: border-box;
}

.icon-home::after {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  border-radius: 3rpx 0 0 0;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.icon-jobs::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 17rpx;
  width: 26rpx;
  height: 21rpx;
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.icon-jobs::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 12rpx;
  width: 12rpx;
  height: 8rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 5rpx 5rpx 0 0;
  box-sizing: border-box;
}

.icon-exp::before {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 10rpx;
  width: 22rpx;
  height: 29rpx;
  border: 4rpx solid currentColor;
  border-radius: 4rpx;
  box-sizing: border-box;
}

.icon-exp::after {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 18rpx;
  width: 11rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 0 7rpx 0 currentColor, 0 14rpx 0 currentColor;
}

.icon-profile::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.icon-profile::after {
  content: "";
  position: absolute;
  left: 13rpx;
  top: 28rpx;
  width: 22rpx;
  height: 11rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 999rpx 999rpx 0 0;
  box-sizing: border-box;
}

.icon-search {
  position: relative;
  flex: 0 0 30rpx;
  width: 30rpx;
  height: 30rpx;
  box-sizing: border-box;
}

.icon-search::before {
  content: "";
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  width: 19rpx;
  height: 19rpx;
  border: 4rpx solid currentColor;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.icon-search::after {
  content: "";
  position: absolute;
  left: 21rpx;
  top: 21rpx;
  width: 11rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: left center;
}

.empty,
.error,
.loading {
  padding: 72rpx 32rpx;
  color: #6b7280;
  text-align: center;
  font-size: 28rpx;
}

.loading {
  color: #9ca3af;
  font-size: 26rpx;
}

.error {
  color: #dc2626;
}

.line-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-2 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.line-3 {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(68rpx + env(safe-area-inset-top)) 28rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f3f4f6;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.back-btn,
.nav-space {
  width: 48rpx;
  height: 48rpx;
  line-height: 42rpx;
  font-size: 54rpx;
  font-weight: 400;
}

.back-btn.icon-back,
.back.icon-back {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 0;
}

.icon-back::before {
  content: "";
  width: 18rpx;
  height: 18rpx;
  margin-left: 6rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 22rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f3f4f6;
}

.primary-button {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 88rpx;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.2);
}

.secondary-button {
  height: 88rpx;
  border: none;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #f97316;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.secondary-button.active {
  background: #f97316;
  color: #ffffff;
}
